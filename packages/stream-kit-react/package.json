{
  "name": "@open-game-system/stream-kit-react",
  "version": "0.0.0",
  "description": "React bindings for @open-game-system/stream-kit-web",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.tsx --format cjs,esm --dts",
    "dev": "tsup src/index.tsx --format cjs,esm --dts --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@open-game-system/stream-kit-types": "workspace:*",
    "@open-game-system/stream-kit-web": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "typescript": ">=4.5.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^28.1.0",
    "react": "^19.2.4",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "typescript",
    "react",
    "hooks",
    "context",
    "stream-kit",
    "cloud-rendering",
    "webrtc",
    "ogs"
  ],
  "author": "OpenGameSystem",
  "license": "MIT"
}