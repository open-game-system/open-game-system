{
  "name": "@open-game-system/stream-kit-react",
  "version": "0.0.0",
  "description": "React bindings for @open-game-system/stream-kit-web",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.tsx --format cjs,esm --dts",
    "dev": "tsup src/index.tsx --format cjs,esm --dts --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@open-game-system/stream-kit-types": "workspace:*",
    "@open-game-system/stream-kit-web": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "typescript": ">=4.5.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.3.24",
    "@vitest/coverage-v8": "^1.6.1",
    "jsdom": "^24.1.3",
    "react": "^18.3.1",
    "rimraf": "^5.0.10",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^1.6.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "typescript",
    "react",
    "hooks",
    "context",
    "stream-kit",
    "cloud-rendering",
    "webrtc",
    "ogs"
  ],
  "author": "OpenGameSystem",
  "license": "MIT"
}