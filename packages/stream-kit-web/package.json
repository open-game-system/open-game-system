{
  "name": "@open-game-system/stream-kit-web",
  "version": "0.0.0",
  "description": "Browser client for streaming with PeerJS",
  "main": "dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@open-game-system/stream-kit-types": "workspace:*",
    "peerjs": "^1.5.5"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "webrtc",
    "peerjs",
    "streaming",
    "browser"
  ],
  "author": "",
  "license": "MIT"
}
