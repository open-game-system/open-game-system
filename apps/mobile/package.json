{
  "name": "@open-game-system/mobile",
  "main": "expo-router/entry",
  "version": "0.0.0",
  "scripts": {
    "eas-build-post-install": "cd ../.. && pnpm turbo run build --filter=@open-game-system/mobile^...",
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild --clean",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "test:ci": "jest --ci --coverage --coverageReporters=json-summary --coverageReporters=text",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test:mutate": "npx stryker run",
    "build:preview:ios": "eas build --profile preview --platform ios --local --non-interactive",
    "build:dev:ios": "eas build --profile development --platform ios --local --non-interactive",
    "e2e:build": "detox build --configuration ios.sim.release",
    "e2e:test": "detox test --configuration ios.sim.release",
    "e2e": "detox build --configuration ios.sim.release && detox test --configuration ios.sim.release"
  },
  "jest": {
    "preset": "jest-expo",
    "testPathIgnorePatterns": [
      "<rootDir>/e2e/"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(.pnpm|((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|@open-game-system/.*|immer|fast-json-patch))"
    ],
    "collectCoverageFrom": [
      "services/**/*.{ts,tsx}",
      "app/**/*.{ts,tsx}",
      "!**/*.d.ts"
    ]
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.6",
    "@expo/vector-icons": "^15.1.1",
    "@open-game-system/app-bridge-native": "workspace:*",
    "@open-game-system/app-bridge-react-native": "workspace:*",
    "@open-game-system/app-bridge-testing": "workspace:*",
    "@open-game-system/app-bridge-types": "workspace:*",
    "@react-native-async-storage/async-storage": "^3.0.1",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "expo": "~55.0.6",
    "expo-blur": "~55.0.9",
    "expo-constants": "~55.0.7",
    "expo-crypto": "^55.0.9",
    "expo-dev-client": "~55.0.16",
    "expo-device": "^55.0.9",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.8",
    "expo-linking": "~55.0.7",
    "expo-notifications": "^55.0.12",
    "expo-router": "~55.0.5",
    "expo-secure-store": "^55.0.8",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.9",
    "expo-web-browser": "~55.0.9",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-google-cast": "^4.9.1",
    "react-native-reanimated": "~4.2.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.2",
    "react-native-webview": "13.16.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/jest-runner": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.14",
    "@types/react-test-renderer": "^19.1.0",
    "detox": "^20.47.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~55.0.0",
    "jest": "^29.7.0",
    "jest-circus": "^29.7.0",
    "jest-expo": "~55.0.9",
    "react-test-renderer": "19.2.4",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "private": true
}
